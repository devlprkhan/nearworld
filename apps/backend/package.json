{
  "name": "@nearworld/backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "private": true,
  "scripts": {
    "dev": "dotenv-cli -e .env -- nodemon",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "dotenv-cli -e .env -- prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "dotenv-cli -e .env -- prisma studio",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "@nearworld/types": "workspace:*",
    "@nearworld/utils": "workspace:*",
    "@prisma/client": "5.22.0",
    "express": "4.21.0",
    "express-async-errors": "3.1.1"
  },
  "devDependencies": {
    "@nearworld/eslint-config": "workspace:*",
    "@nearworld/tsconfig": "workspace:*",
    "@types/express": "4.17.21",
    "@types/node": "20.16.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "dotenv-cli": "7.4.4",
    "eslint": "^9.39.4",
    "nodemon": "3.1.7",
    "prisma": "5.22.0",
    "ts-node-dev": "2.0.0"
  }
}
